# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_SECRET_KEY

# WhatsApp Business API (Meta)
WHATSAPP_API_TOKEN=YOUR_WHATSAPP_BUSINESS_TOKEN
WHATSAPP_PHONE_ID=YOUR_PHONE_NUMBER_ID

# Email Configuration (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Server
PORT=3000

# Airbnb Calendar URLs (get from Airbnb listing settings)
# Format: Property ID = iCal URL
AIRBNB_ICAL_1=https://www.airbnb.com/calendar/ical/YOUR_LISTING_1.ics
AIRBNB_ICAL_2=https://www.airbnb.com/calendar/ical/YOUR_LISTING_2.ics
AIRBNB_ICAL_3=https://www.airbnb.com/calendar/ical/YOUR_LISTING_3.ics
